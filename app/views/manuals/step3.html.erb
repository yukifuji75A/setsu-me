<div class="pt-8 pb-4">
  <h1 class="text-xl font-bold mb-1">最終確認</h1>
  <p class="text-sm text-gray-400">以下の内容でトリセツを発行します。</p>
</div>

<div class="space-y-4 mb-8">
  <div class="bg-white border-2 border-violet-500 rounded-2xl p-4">
    <p class="text-xs text-gray-400 mb-3">プロフィール</p>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">名前</dt>
        <dd class="text-gray-900"><%= @profile.name %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">年齢</dt>
        <dd class="text-gray-900"><%= @profile.age %>歳</dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">星座</dt>
        <dd class="text-gray-900"><%= @profile.zodiac_sign %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">血液型</dt>
        <dd class="text-gray-900"><%= t("enums.profile.blood_type.#{@profile.blood_type}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">出身地</dt>
        <dd class="text-gray-900"><%= t("enums.profile.hometown.#{@profile.hometown}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-gray-400">学歴</dt>
        <dd class="text-gray-900"><%= t("enums.profile.education.#{@profile.education}") %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-white border-2 border-violet-500 rounded-2xl p-4">
    <p class="text-xs text-gray-400 mb-3">共通情報</p>
    <dl class="space-y-3 text-sm">
      <% @common_answers.each do |answer| %>
        <div>
          <dt class="text-gray-400 text-xs mb-0.5"><%= answer.question.title %></dt>
          <dd class="text-gray-900">
            <% if answer.question.selection? %>
              <%= answer.question_option&.label %>
            <% else %>
              <%= answer.body %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="bg-white border-2 border-violet-500 rounded-2xl p-4">
    <p class="text-xs text-gray-400 mb-2">製品概要</p>
    <p class="text-sm leading-relaxed text-gray-900"><%= @basic_spec&.ai_text %></p>
  </div>
</div>

<%= form_with url: step3_manuals_path, method: :post, data: { turbo: false } do |f| %>
  <div class="space-y-3">
    <%= f.submit "トリセツを発行する",
        class: "w-full py-4 rounded-2xl font-bold text-white text-sm cursor-pointer bg-gradient-to-r from-accent-purple to-accent-pink hover:opacity-90 transition-opacity" %>
    <%= link_to "戻る", step2_manuals_path,
        class: "block w-full py-4 rounded-2xl font-bold text-sm text-center border-2 border-violet-500 text-violet-500 hover:bg-violet-50 transition-colors" %>
  </div>
<% end %>
