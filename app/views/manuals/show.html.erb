<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-8">あなたのトリセツ</h1>

  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">プロフィール</h2>
    <dl class="space-y-3 text-sm bg-gray-50 rounded-lg p-4">
      <div class="flex gap-4">
        <dt class="w-24 text-gray-500">表示名</dt>
        <dd><%= @profile.name %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-500">生年月日</dt>
        <dd><%= @profile.birthday.strftime("%Y年%m月%d日") %>（<%= @profile.age %>歳・<%= @profile.zodiac_sign %>）</dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-500">血液型</dt>
        <dd><%= t("enums.profile.blood_type.#{@profile.blood_type}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-500">出身地</dt>
        <dd><%= t("enums.profile.hometown.#{@profile.hometown}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-500">学歴</dt>
        <dd><%= t("enums.profile.education.#{@profile.education}") %></dd>
      </div>
    </dl>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">共通情報</h2>
    <dl class="space-y-4 text-sm bg-gray-50 rounded-lg p-4">
      <% @common_answers.each do |answer| %>
        <div>
          <dt class="text-gray-500 mb-1"><%= answer.question.title %></dt>
          <dd class="font-medium">
            <% if answer.question.selection? %>
              <%= answer.question_option&.label %>
            <% else %>
              <%= answer.body %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">基本スペック</h2>
    <div class="p-4 bg-gray-50 rounded-lg text-sm leading-relaxed">
      <%= @basic_spec&.ai_text %>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">取扱いガイド</h2>
    <div class="p-4 bg-gray-50 rounded-lg text-sm leading-relaxed">
      <%= @handling_guide&.ai_text %>
    </div>
  </section>

  <%= link_to "マイページへ", mypage_path,
      class: "inline-block bg-black text-white px-8 py-3 rounded-lg font-medium hover:bg-gray-800" %>
</div>
