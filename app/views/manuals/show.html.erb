<%# ダーク背景 %>

<div class="pt-8 pb-4">
  <h1 class="text-xl font-bold mb-1"><%= @profile.name %>のトリセツ</h1>
</div>

<div class="space-y-4 mb-8">
  <div class="bg-dark-card rounded-2xl p-4">
    <p class="text-xs text-dark-muted mb-3">プロフィール</p>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">名前</dt>
        <dd><%= @profile.name %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">年齢</dt>
        <dd><%= @profile.age %>歳</dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">星座</dt>
        <dd><%= @profile.zodiac_sign %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">血液型</dt>
        <dd><%= t("enums.profile.blood_type.#{@profile.blood_type}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">出身地</dt>
        <dd><%= t("enums.profile.hometown.#{@profile.hometown}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-20 text-dark-muted">学歴</dt>
        <dd><%= t("enums.profile.education.#{@profile.education}") %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-dark-card rounded-2xl p-4">
    <p class="text-xs text-dark-muted mb-3">共通情報</p>
    <dl class="space-y-3 text-sm">
      <% @common_answers.each do |answer| %>
        <div>
          <dt class="text-dark-muted text-xs mb-0.5"><%= answer.question.title %></dt>
          <dd>
            <% if answer.question.selection? %>
              <%= answer.question_option&.label %>
            <% else %>
              <%= answer.body %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="bg-dark-card rounded-2xl p-4">
    <p class="text-xs text-dark-muted mb-2">基本スペック</p>
    <p class="text-sm leading-relaxed"><%= @basic_spec&.ai_text %></p>
  </div>

  <div class="bg-dark-card rounded-2xl p-4">
    <p class="text-xs text-dark-muted mb-2">取扱いガイド</p>
    <p class="text-sm leading-relaxed"><%= @handling_guide&.ai_text %></p>
  </div>
</div>

<%= link_to "マイページへ", mypage_path,
    class: "block w-full py-4 rounded-2xl font-bold text-sm text-center bg-gradient-to-r from-accent-purple to-accent-pink text-white hover:opacity-90 transition-opacity" %>
