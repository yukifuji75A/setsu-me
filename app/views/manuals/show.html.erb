<%# 白背景（inputレイアウト） %>

<%# ヘッダー %>
<div class="pt-8 pb-6">
  <p class="text-xs text-gray-400 tracking-widest mb-1">取扱説明書</p>
  <h1 class="text-2xl font-bold bg-gradient-to-r from-accent-purple to-accent-pink bg-clip-text text-transparent">
    <%= @profile.name %>
  </h1>
  <p class="text-xs text-gray-600 mt-1 tracking-widest">型番：<%= manual_serial_number(@manual) %></p>
  <div class="mt-3 h-px bg-gradient-to-r from-accent-purple to-accent-pink opacity-50"></div>
</div>

<div class="space-y-4 mb-8">

  <%# 第1章 %>
  <div class="bg-white border-2 border-violet-500 rounded-2xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-violet-200">
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gradient-to-r from-accent-purple to-accent-pink text-white">第1章</span>
      <span class="text-sm font-semibold ml-2 text-gray-900">製品概要</span>
    </div>
    <dl class="space-y-2 text-sm p-4">
      <div class="flex gap-4">
        <dt class="w-24 text-gray-400">製造年</dt>
        <dd class="text-gray-900"><%= @profile.birthday.year %>年</dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-400">製造地</dt>
        <dd class="text-gray-900"><%= t("enums.profile.hometown.#{@profile.hometown}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-400">モデル属性</dt>
        <dd class="text-gray-900"><%= @profile.zodiac_sign %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-400">内部規格</dt>
        <dd class="text-gray-900"><%= t("enums.profile.blood_type.#{@profile.blood_type}") %></dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 text-gray-400">開発履歴</dt>
        <dd class="text-gray-900"><%= t("enums.profile.education.#{@profile.education}") %></dd>
      </div>
    </dl>
  </div>

  <%# 第2章 %>
  <div class="bg-white border-2 border-violet-500 rounded-2xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-violet-200">
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gradient-to-r from-accent-purple to-accent-pink text-white">第2章</span>
      <span class="text-sm font-semibold ml-2 text-gray-900">製品仕様</span>
    </div>
    <dl class="space-y-3 text-sm p-4">
      <% @common_answers.each do |answer| %>
        <div>
          <dt class="text-gray-400 text-xs mb-0.5"><%= answer.question.display_label %></dt>
          <dd class="text-gray-900">
            <% if answer.question.selection? %>
              <%= answer.question_option&.label %>
            <% else %>
              <%= answer.body %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%# 第3章 %>
  <div class="bg-white border-2 border-violet-500 rounded-2xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-violet-200">
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gradient-to-r from-accent-purple to-accent-pink text-white">第3章</span>
      <span class="text-sm font-semibold ml-2 text-gray-900">推奨環境</span>
    </div>
    <p class="text-sm leading-relaxed p-4 text-gray-900"><%= @basic_spec&.ai_text %></p>
  </div>

  <%# 第4章 %>
  <div class="bg-white border-2 border-violet-500 rounded-2xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-violet-200">
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gradient-to-r from-accent-purple to-accent-pink text-white">第4章</span>
      <span class="text-sm font-semibold ml-2 text-gray-900">非推奨・注意事項</span>
    </div>
    <p class="text-sm leading-relaxed p-4 text-gray-900"><%= @handling_guide&.ai_text %></p>
  </div>

  <%# 第5章 %>
  <div class="bg-white border-2 border-violet-500 rounded-2xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-violet-200">
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gradient-to-r from-accent-purple to-accent-pink text-white">第5章</span>
      <span class="text-sm font-semibold ml-2 text-gray-900">トラブル対処</span>
    </div>
    <div class="p-4 text-sm text-gray-400 text-center">
      準備中
    </div>
  </div>

</div>

<%= link_to "マイページへ", mypage_path,
    class: "block w-full py-4 rounded-2xl font-bold text-sm text-center bg-gradient-to-r from-accent-purple to-accent-pink text-white hover:opacity-90 transition-opacity" %>
