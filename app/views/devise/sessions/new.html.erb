<%# ダーク背景 %>

<div class="flex flex-col items-center pt-12 pb-8">
  <%# ロゴ %>
  <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-accent-purple to-accent-pink flex items-center justify-center mb-4">
    <span class="text-2xl">📋</span>
  </div>
  <h1 class="text-2xl font-bold tracking-wide mb-1">トリセツ</h1>
  <p class="text-dark-muted text-sm">あなただけの取扱説明書</p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-3 mb-6">
    <div class="bg-dark-card border border-dark-border rounded-2xl px-4 py-3">
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "メールアドレス",
          class: "w-full bg-transparent text-white placeholder-dark-muted text-sm outline-none" %>
    </div>

    <div class="bg-dark-card border border-dark-border rounded-2xl px-4 py-3">
      <%= f.password_field :password,
          autocomplete: "current-password",
          placeholder: "パスワード",
          class: "w-full bg-transparent text-white placeholder-dark-muted text-sm outline-none" %>
    </div>
  </div>

  <%= f.submit "ログイン",
      class: "w-full py-4 rounded-2xl font-bold text-white text-sm cursor-pointer bg-gradient-to-r from-accent-purple to-accent-pink hover:opacity-90 transition-opacity" %>
<% end %>

<p class="text-center text-dark-muted text-sm mt-8">
  アカウントをお持ちでない方は
  <%= link_to "新規登録", new_user_registration_path, class: "text-accent-purple hover:underline" %> →
</p>
